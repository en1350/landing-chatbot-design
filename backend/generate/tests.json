{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET method not allowed",
      "method": "GET",
      "path": "/",
      "expectedStatus": 405,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "unknown_xyz"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Generate unknown type returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "generate", "type": "unknown_type", "fields": {}},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Refine without content returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "refine", "content": "", "instruction": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Chat without message returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "chat", "message": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Decompose without competency returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "decompose", "competency": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Notebook check without image returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "notebook_check", "image_base64": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}