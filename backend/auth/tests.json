{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET without token returns 401",
      "method": "GET",
      "path": "/",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST unknown action returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "unknown_xyz"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong credentials returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "nonexistent_test_user@example.com", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Register without privacy consent returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "email": "consent_test@example.com", "password": "password123", "privacy_accepted": false},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Reset password with invalid token returns 404",
      "method": "POST",
      "path": "/",
      "body": {"action": "reset_password", "token": "invalid_token_xyz", "new_password": "newpassword123"},
      "expectedStatus": 404,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "register_use without auth returns 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "register_use", "type": "lesson"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}